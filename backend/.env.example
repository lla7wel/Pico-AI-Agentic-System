# Bootstrap-only environment. Copy to .env for local runs.
#
# NOTE: API keys, model, system prompt, response tuning, and device tokens are
# NOT set here — they are configured at runtime in the web dashboard and
# stored in the database. This file only holds what's needed to boot.

# Where the SQLite DB lives (settings, devices, history, events).
# Locally use a file in the cwd; on Fly it's the mounted volume (/data/app.db).
SQLITE_PATH=./app.db

# First-run dashboard password. Only used to seed login the very first time the
# DB is created; afterwards change it in the dashboard (this is then ignored).
ADMIN_PASSWORD=admin

# Dashboard session lifetime, hours.
SESSION_TTL_HOURS=12

# Optional: if a Pico was already flashed with a fixed PICO_AUTH_TOKEN, put it
# here so a device row is seeded on first run and that Pico keeps working.
# Ignored once any device exists. Otherwise create devices in the dashboard.
PICO_AUTH_TOKEN=
