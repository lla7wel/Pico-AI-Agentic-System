# Copy to .env for local runs, or set these as Fly.io secrets in prod.
# --- Required secrets ---
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
PICO_AUTH_TOKEN=          # shared secret; must match secrets.h on the Pico

# --- Tunables (defaults shown) ---
CLAUDE_MODEL=claude-haiku-4-5-20251001   # swap to claude-sonnet-5 for more reasoning
SQLITE_PATH=/data/conversations.db       # on the Fly volume in prod; ./conversations.db locally
SAMPLE_RATE=16000
HISTORY_TURNS=10
MAX_RESPONSE_CHARS=400
