// secrets.h.example — copy to secrets.h and fill in. secrets.h is gitignored.
// The firmware-side counterpart to the backend .env.
#pragma once

#define WIFI_SSID        "your-wifi-ssid"
#define WIFI_PASS        "your-wifi-password"

// Backend host/port. After `fly deploy`, use your Fly app's hostname.
#define WS_HOST          "pico-voice-agent.fly.dev"
#define WS_PORT          443
#define WS_PATH          "/ws/voice"

// Device token + id: GENERATE THESE IN THE DASHBOARD (Devices → Add a Pico).
// The dashboard shows both values once, ready to paste here. Rotating the
// token in the dashboard means re-flashing with the new value.
#define PICO_AUTH_TOKEN  "paste-token-from-dashboard"

// Must match the device_id shown in the dashboard for this device.
#define DEVICE_ID        "pico-01"
